---
interface Props {
  visual?: string;
  title: string;
  label?: string;
  compact?: boolean;
}

const { visual = "visual-slate", title, label, compact = false } = Astro.props;
---

<div class:list={[
  "relative overflow-hidden rounded-lg border border-white/10",
  compact ? "aspect-[4/3]" : "aspect-[16/10]",
  visual,
]}>
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_48%_42%,transparent,rgba(5,6,8,0.34))]"></div>
  <div class="absolute left-4 top-4 flex gap-1.5">
    <span class="h-2 w-2 rounded-full bg-signal"></span>
    <span class="h-2 w-2 rounded-full bg-ember"></span>
    <span class="h-2 w-2 rounded-full bg-violet"></span>
  </div>
  <div class="absolute bottom-4 left-4 right-4">
    {label && <p class="mb-2 text-xs font-semibold uppercase tracking-[0.18em] text-white/60">{label}</p>}
    <p class="font-display text-xl font-semibold leading-tight text-white md:text-2xl">{title}</p>
  </div>
</div>
