---
import type { CollectionEntry } from "astro:content";
import { CodeXmlIcon, ExternalLinkIcon, XIcon } from "@lucide/astro";
import VisualPanel from "./VisualPanel.astro";

interface Props {
  entry: CollectionEntry<"work">;
  Content: any;
}

const { entry, Content } = Astro.props;
const detailId = `work-${entry.id}`;
const galleryGridClasses =
  entry.data.gallery.length >= 3 ? "mt-4 grid gap-4 sm:grid-cols-2 xl:grid-cols-3" : "mt-4 grid gap-4 sm:grid-cols-2";
---

<section
  id={detailId}
  class="fixed inset-0 z-50 hidden items-center justify-center bg-black/78 p-4 backdrop-blur-md"
  role="dialog"
  aria-modal="true"
  aria-labelledby={`${detailId}-title`}
  data-lightbox
>
  <div class="max-h-[92vh] w-full max-w-6xl overflow-y-auto rounded-lg border border-white/12 bg-panel shadow-glow">
    <div class="sticky top-0 z-10 flex items-center justify-between gap-4 border-b border-white/10 bg-panel/95 px-5 py-4 backdrop-blur md:px-7">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-signal">{entry.data.category} / {entry.data.year}</p>
        <h2 id={`${detailId}-title`} class="mt-1 font-display text-2xl font-semibold text-chalk md:text-3xl">{entry.data.title}</h2>
      </div>
      <button
        type="button"
        class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-white/10 text-white/80 transition hover:border-ember/70 hover:text-white"
        data-close-lightbox
        aria-label={`Close ${entry.data.title}`}
      >
        <XIcon size={20} aria-hidden="true" />
      </button>
    </div>

    <div class="p-5 md:p-7">
      <div class="grid gap-8 md:grid-cols-[minmax(0,1.2fr)_minmax(18rem,0.8fr)]">
        <VisualPanel
          visual={entry.data.thumbnail}
          image={entry.data.thumbnailImage}
          title={entry.data.title}
          label={entry.data.subtitle ?? entry.data.role}
        />

        <aside class="h-fit rounded-lg border border-white/10 bg-white/[0.035] p-5">
          <p class="text-sm font-semibold uppercase tracking-[0.16em] text-white/55">Project Details</p>
          <dl class="mt-5 space-y-5">
            <div>
              <dt class="text-sm text-muted">Role</dt>
              <dd class="mt-1 font-medium text-chalk">{entry.data.role}</dd>
            </div>
            <div>
              <dt class="text-sm text-muted">Tools</dt>
              <dd class="mt-2 flex flex-wrap gap-2">
                {entry.data.tools.map((tool) => (
                  <span class="rounded-full bg-white/8 px-3 py-1 text-xs font-semibold text-white/78">{tool}</span>
                ))}
              </dd>
            </div>
            <div>
              <dt class="text-sm text-muted">Tags</dt>
              <dd class="mt-2 flex flex-wrap gap-2">
                {entry.data.tags.map((tag) => (
                  <span class="rounded-full border border-white/10 px-3 py-1 text-xs text-white/70">{tag}</span>
                ))}
              </dd>
            </div>
          </dl>

          <div class="mt-6 grid gap-3">
            {entry.data.liveUrl && (
              <a class="inline-flex items-center justify-center gap-2 rounded-md bg-signal px-4 py-3 text-sm font-bold text-ink transition hover:bg-white" href={entry.data.liveUrl} target="_blank" rel="noreferrer">
                View Live <ExternalLinkIcon size={16} aria-hidden="true" />
              </a>
            )}
            {entry.data.repoUrl && (
              <a class="inline-flex items-center justify-center gap-2 rounded-md border border-white/12 px-4 py-3 text-sm font-bold text-chalk transition hover:border-signal/70" href={entry.data.repoUrl} target="_blank" rel="noreferrer">
                View Code <CodeXmlIcon size={16} aria-hidden="true" />
              </a>
            )}
            {entry.data.caseStudyUrl && (
              <a class="inline-flex items-center justify-center gap-2 rounded-md border border-white/12 px-4 py-3 text-sm font-bold text-chalk transition hover:border-signal/70" href={entry.data.caseStudyUrl} target="_blank" rel="noreferrer">
                Full Case Study <ExternalLinkIcon size={16} aria-hidden="true" />
              </a>
            )}
          </div>
        </aside>
      </div>

      {entry.data.gallery.length > 0 && (
        <div class={galleryGridClasses}>
          {entry.data.gallery.map((item) => (
            <figure>
              <VisualPanel
                visual={item.visual}
                image={item.type === "video" ? undefined : item.image}
                video={item.type === "video" ? item.video : undefined}
                title={item.title}
                label="Gallery"
                compact
              />
              <figcaption class="mt-2 text-sm leading-6 text-muted">{item.caption}</figcaption>
            </figure>
          ))}
        </div>
      )}

      <div class="case-study mt-8">
        <Content />
      </div>
    </div>
  </div>
</section>
